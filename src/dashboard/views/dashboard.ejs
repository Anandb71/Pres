<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="PResolution activity dashboard.">
  <title>Dashboard — PResolution</title>
  <link rel="stylesheet" href="/static/style.css">
  <link rel="icon" href="/static/logo.svg" type="image/svg+xml">
</head>

<body>
  <div class="page-progress" aria-hidden="true"><div class="page-progress-bar" id="page-progress"></div></div>
  <div class="bg-noise" aria-hidden="true"></div>
  <div class="bg-orb bg-orb-a" aria-hidden="true"></div>
  <div class="bg-orb bg-orb-b" aria-hidden="true"></div>

  <header class="site-header">
    <div class="container nav-wrap">
      <a href="/" class="brand" aria-label="PResolution home">
        <img src="/static/logo.svg" alt="PResolution logo" class="brand-logo">
        <span class="brand-name">PResolution</span>
      </a>
      <nav aria-label="Primary navigation">
        <ul class="nav-links">
          <li><a href="/">Home</a></li>
          <li><a class="active" href="/dashboard">Dashboard</a></li>
          <li><a href="/setup">Setup</a></li>
          <li><a href="/status">Status</a></li>
        </ul>
      </nav>
      <a class="btn btn-primary nav-cta" href="/github">Open Repo</a>
    </div>
  </header>

  <main class="section">
    <div class="container page-shell">
      <section class="panel reveal is-visible">
        <div class="panel-head">
          <div>
            <p class="kicker">Live metrics</p>
            <h1 class="page-title">Activity dashboard</h1>
          </div>
          <button class="btn btn-secondary" onclick="window.location.reload()">Refresh</button>
        </div>

        <div class="stats-grid dashboard-stats">
          <div class="stat"><p class="stat-value"><%= stats.totalFixes || 0 %></p><p class="stat-label">Total fixes</p></div>
          <div class="stat"><p class="stat-value"><%= stats.successRate || 0 %>%</p><p class="stat-label">Success rate</p></div>
          <div class="stat"><p class="stat-value"><%= stats.avgTimeMs ? (stats.avgTimeMs / 1000).toFixed(1) + 's' : '—' %></p><p class="stat-label">Avg fix time</p></div>
          <div class="stat"><p class="stat-value"><%= stats.reposServed || 0 %></p><p class="stat-label">Repos served</p></div>
        </div>
      </section>

      <section class="panel reveal is-visible">
        <div class="panel-head">
          <h2>Recent activity</h2>
          <span class="subtle">Latest 50 jobs</span>
        </div>

        <% if (activities.length > 0) { %>
          <div class="table-wrap">
            <table class="dash-table">
              <thead>
                <tr>
                  <th>Status</th>
                  <th>Repository</th>
                  <th>PR</th>
                  <th>File</th>
                  <th>Reviewer</th>
                  <th>Time</th>
                  <th>Commit</th>
                </tr>
              </thead>
              <tbody>
                <% activities.forEach((activity) => { %>
                  <tr>
                    <td>
                      <span class="status-pill <%= activity.status %>">
                        <%= activity.status === 'success' ? 'Success' : activity.status === 'failed' ? 'Failed' : 'Processing' %>
                      </span>
                    </td>
                    <td><code><%= activity.repo %></code></td>
                    <td>#<%= activity.pullNumber %></td>
                    <td><code><%= activity.filePath || '—' %></code></td>
                    <td>@<%= activity.reviewer %></td>
                    <td><%= activity.processingTimeMs ? (activity.processingTimeMs / 1000).toFixed(1) + 's' : '—' %></td>
                    <td>
                      <% if (activity.commitSha && activity.commitUrl) { %>
                        <a href="<%= activity.commitUrl %>" target="_blank" rel="noopener"><code><%= activity.commitSha.slice(0, 7) %></code></a>
                      <% } else { %>
                        —
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="empty-card">
            <h3>No activity yet</h3>
            <p>Run your first command with <code>@PResolve /fix</code> in a PR review thread and it will show up here.</p>
          </div>
        <% } %>
      </section>
    </div>
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div>
        <a href="/" class="brand footer-brand">
          <img src="/static/logo.svg" alt="PResolution logo" class="brand-logo">
          <span class="brand-name">PResolution</span>
        </a>
        <p>Operational dashboard for automated PR fixes.</p>
      </div>
      <div>
        <h4>Links</h4>
        <a href="/">Home</a>
        <a href="/setup">Setup</a>
        <a href="/status">Status</a>
      </div>
      <div>
        <h4>Project</h4>
        <a href="/github">Repository</a>
      </div>
    </div>
  </footer>

  <script>
    (() => {
      const bar = document.getElementById('page-progress');
      const update = () => {
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const p = max > 0 ? window.scrollY / max : 0;
        if (bar) bar.style.transform = `scaleX(${Math.max(0, Math.min(1, p))})`;
      };
      window.addEventListener('scroll', () => requestAnimationFrame(update), { passive: true });
      update();
    })();
  </script>
</body>

</html>
