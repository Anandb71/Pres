# ===========================================
#  PResolution — Environment Configuration
# ===========================================

# GitHub App Configuration
# Found at: https://github.com/settings/apps/YOUR_APP
APP_ID=

# Local development: point to your downloaded .pem file
PRIVATE_KEY_PATH=./private-key.pem
# Cloud/Render: paste the entire PEM contents as a single env var instead.
# In the Render dashboard UI you can paste multi-line; in a .env file escape
# newlines as literal \n.  Do NOT set both PRIVATE_KEY_PATH and PRIVATE_KEY.
# PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

WEBHOOK_SECRET=replace_with_strong_random_secret
# Leave blank on Render — Render gives you a real public HTTPS URL automatically
WEBHOOK_PROXY_URL=

# AI Provider — Google Gemini
GEMINI_API_KEY=

# AI provider selection
# Supported: gemini | openai | openai-compatible | github-models
AI_PROVIDER=gemini

# Optional: Override AI model
# Gemini example: gemini-2.0-flash
# OpenAI/GitHub Models example: gpt-4o-mini
# AI_MODEL=

# OpenAI / OpenAI-compatible providers
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Groq (OpenAI-compatible) example
# AI_PROVIDER=openai-compatible
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=your_groq_api_key
# AI_MODEL=openai/gpt-oss-120b

# For github-models provider, use your GitHub token
# GITHUB_TOKEN=

# Logging
# Options: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Server
# Local default. On Render, PORT is injected automatically — do NOT set it there.
PORT=3000
# Set to "production" on Render (done automatically via render.yaml)
NODE_ENV=development

# Dashboard security (required in production)
DASHBOARD_ACCESS_TOKEN=replace_with_long_random_token
# Example: 60000 = 1 minute window
DASHBOARD_RATE_WINDOW_MS=60000
# Max requests per IP per window
DASHBOARD_RATE_MAX_REQUESTS=240

# Optional local preview activity source file (JSON array)
PREVIEW_ACTIVITY_FILE=
