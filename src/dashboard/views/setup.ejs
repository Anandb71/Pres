<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="PResolution setup guide.">
  <title>Setup — PResolution</title>
  <link rel="stylesheet" href="/static/style.css">
  <link rel="icon" href="/static/logo.svg" type="image/svg+xml">
</head>

<body>
  <div class="page-progress" aria-hidden="true"><div class="page-progress-bar" id="page-progress"></div></div>
  <div class="bg-noise" aria-hidden="true"></div>
  <div class="bg-orb bg-orb-a" aria-hidden="true"></div>
  <div class="bg-orb bg-orb-b" aria-hidden="true"></div>

  <header class="site-header">
    <div class="container nav-wrap">
      <a href="/" class="brand" aria-label="PResolution home">
        <img src="/static/logo.svg" alt="PResolution logo" class="brand-logo">
        <span class="brand-name">PResolution</span>
      </a>
      <nav aria-label="Primary navigation">
        <ul class="nav-links">
          <li><a href="/">Home</a></li>
          <li><a href="/dashboard">Dashboard</a></li>
          <li><a class="active" href="/setup">Setup</a></li>
          <li><a href="/status">Status</a></li>
        </ul>
      </nav>
      <a class="btn btn-primary nav-cta" href="/github">Open Repo</a>
    </div>
  </header>

  <main class="section">
    <div class="container page-shell">
      <section class="panel reveal is-visible">
        <p class="kicker">Deployment guide</p>
        <h1 class="page-title">Setup in five steps</h1>
        <p class="subtle">Get PResolution running end-to-end in a few minutes.</p>
      </section>

      <section class="panel reveal is-visible">
        <ol class="setup-list">
          <li>
            <h3>Create a GitHub App</h3>
            <p>Create your app at <a href="https://github.com/settings/apps/new" target="_blank" rel="noreferrer">github.com/settings/apps/new</a>.</p>
            <ul>
              <li>Pull Requests: <code>Read & Write</code></li>
              <li>Contents: <code>Read & Write</code></li>
              <li>Issues: <code>Read & Write</code></li>
              <li>Metadata: <code>Read</code></li>
            </ul>
          </li>

          <li>
            <h3>Clone the project</h3>
            <div class="code-card">
              <code>git clone https://github.com/Anandb71/Pres.git</code>
              <code>cd Pres</code>
              <code>npm install</code>
              <code>copy .env.example .env</code>
            </div>
          </li>

          <li>
            <h3>Configure environment</h3>
            <div class="code-card">
              <code>APP_ID=your_app_id</code>
              <code>PRIVATE_KEY_PATH=./private-key.pem</code>
              <code>WEBHOOK_SECRET=your_webhook_secret</code>
              <code>GEMINI_API_KEY=your_api_key</code>
            </div>
          </li>

          <li>
            <h3>Run locally</h3>
            <div class="code-card">
              <code>npm run dev</code>
              <code>npm run build</code>
              <code>npm start</code>
            </div>
          </li>

          <li>
            <h3>Install and test</h3>
            <p>Install the app on your repository, leave a PR review comment, then reply with <code>@PResolve /fix</code>.</p>
          </li>
        </ol>
      </section>
    </div>
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div>
        <a href="/" class="brand footer-brand">
          <img src="/static/logo.svg" alt="PResolution logo" class="brand-logo">
          <span class="brand-name">PResolution</span>
        </a>
        <p>Fast onboarding for your code review automation stack.</p>
      </div>
      <div>
        <h4>Links</h4>
        <a href="/">Home</a>
        <a href="/dashboard">Dashboard</a>
        <a href="/status">Status</a>
      </div>
      <div>
        <h4>Project</h4>
        <a href="/github">Repository</a>
      </div>
    </div>
  </footer>

  <script>
    (() => {
      const bar = document.getElementById('page-progress');
      const update = () => {
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const p = max > 0 ? window.scrollY / max : 0;
        if (bar) bar.style.transform = `scaleX(${Math.max(0, Math.min(1, p))})`;
      };
      window.addEventListener('scroll', () => requestAnimationFrame(update), { passive: true });
      update();
    })();
  </script>
</body>

</html>
